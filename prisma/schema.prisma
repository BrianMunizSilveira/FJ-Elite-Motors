// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VehicleType {
  CAR
  MOTORCYCLE
}

enum VehicleStatus {
  DRAFT
  AVAILABLE
  RESERVED
  SOLD
}

model Vehicle {
  id           String        @id @default(uuid())
  type         VehicleType   @default(CAR)
  brand        String
  model        String
  yearModel    Int
  yearFab      Int
  mileage      Int
  price        Decimal       @db.Decimal(15, 2)
  description  String?       @db.Text
  fuelType     String?
  transmission String?
  color        String?
  isHighlight  Boolean       @default(false)
  status       VehicleStatus @default(AVAILABLE)
  images       VehicleImage[]
  sales        Sale[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("vehicles")
}

model VehicleImage {
  id        String   @id @default(uuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  url       String   @db.Text
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("vehicle_images")
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  document  String?  @unique // CPF/CNPJ
  address   String?
  sales     Sale[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customers")
}

model Employee {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      String   @default("sales") // sales, manager, admin
  password  String
  sales     Sale[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employees")
}

model Sale {
  id         String   @id @default(uuid())
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  saleDate   DateTime @default(now())
  salePrice  Decimal  @db.Decimal(15, 2)
  notes      String?  @db.Text
  createdAt  DateTime @default(now())

  @@map("sales")
}

model Page {
  slug            String   @id
  title           String
  content         String   @db.Text
  metaTitle       String?
  metaDescription String?
  updatedAt       DateTime @updatedAt

  @@map("pages")
}
